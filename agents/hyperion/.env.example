# agents/hyperion/.env.example
# Copy to .env: cp .env.example .env
#
# Values here take priority over ~/ai/ai-router/.env.
# The LiteLLM proxy (ai-router/.env) holds the actual provider API keys.

# =============================================================================
# LiteLLM virtual key for Hyperion ($10/day budget, 60 rpm)
# Create: bash scripts/create_hyperion_key.sh
# Falls back to LITELLM_MASTER_KEY from ai-router/.env if not set.
# =============================================================================
LITELLM_HYPERION_KEY=sk-hyperion-change-me

# =============================================================================
# Langfuse tracing (http://localhost:3001)
# Keys are auto-generated during docker compose up; copy from ai-router/.env
# or from the Langfuse UI (Project Settings → API Keys).
# =============================================================================
LANGFUSE_PUBLIC_KEY=pk-lf-change-me
LANGFUSE_SECRET_KEY=sk-lf-change-me
LANGFUSE_HOST=http://localhost:3001

# =============================================================================
# Model assignments
#
# Each role uses a LiteLLM alias that is a multi-provider group. The proxy
# automatically picks from providers whose API keys are present in ai-router/.env
# and falls back across providers if one is unavailable.
#
# Alias → provider fallback order (configured in ai-router/litellm_config.yaml):
#   smart  → Claude Opus 4.6   → Gemini 2.5 Pro  → GPT-4o
#   worker → Claude Sonnet 4.6 → Gemini 2.5 Pro  → GPT-4o
#   cheap  → Claude Haiku 4.5  → Gemini 2.5 Flash → GPT-4o-mini
#   fast   → Gemini 2.5 Flash  → Claude Haiku 4.5 → GPT-4o-mini
#
# You can also pin a specific model instead of an alias:
#   MODEL_PLANNER=gemini-2.5-pro      # always use Gemini Pro for planning
#   MODEL_WORKER=gpt-4o               # always use GPT-4o for research
#   MODEL_CHEAP=gpt-4o-mini           # always use the cheapest OpenAI model
#
# See GET http://localhost:4100/config for current effective assignments.
# =============================================================================
MODEL_PLANNER=smart      # best reasoning model available across providers
MODEL_WORKER=worker      # balanced cost/quality for researcher + synthesizer
MODEL_CHEAP=cheap        # low-cost for summarization sub-calls

# =============================================================================
# Task circuit breakers (override defaults; can also be set per-request)
# =============================================================================
# CAP_INPUT_TOKENS=400000
# CAP_OUTPUT_TOKENS=80000
# CAP_TOOL_LOOP=3
# CAP_WALL_SECONDS=900

# =============================================================================
# Infrastructure URLs (defaults match the docker-compose setup)
# =============================================================================
# LITELLM_BASE_URL=http://localhost:4000/v1
# QDRANT_URL=http://localhost:6333
# SEARXNG_URL=http://localhost:8888
# INFINITY_URL=http://localhost:7997

# =============================================================================
# Critic agent (off | planner | always)
# =============================================================================
# HYPERION_CRITIC_DEFAULT=off
