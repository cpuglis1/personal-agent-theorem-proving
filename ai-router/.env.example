# =============================================================================
# .env.example  —  copy to .env and fill in real values
#   cp .env.example .env
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Provider API Keys — all optional; include whichever providers you use.
#
# LiteLLM's role aliases (smart / worker / cheap / fast) are multi-provider
# groups. Adding a key here immediately makes those models available; removing
# one silently routes around that provider. At least one provider must be set.
#
# Alias fallback order (see litellm_config.yaml for full detail):
#   smart  → Claude Opus  → Gemini Pro   → GPT-4o
#   worker → Claude Sonnet → Gemini Pro  → GPT-4o
#   cheap  → Claude Haiku → Gemini Flash → GPT-4o-mini
# -----------------------------------------------------------------------------

# Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI Platform: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here

# Anthropic Console: https://console.anthropic.com/settings/keys
# NOT your Claude Max subscription — this is the separate pay-per-use API.
# Leave unset to route around Claude models automatically.
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# -----------------------------------------------------------------------------
# LiteLLM Proxy
# -----------------------------------------------------------------------------
# Master key — used by Open WebUI and agent scripts to authenticate with LiteLLM
# Generate: python3 -c "import secrets; print('sk-' + secrets.token_hex(24))"
LITELLM_MASTER_KEY=sk-change-me-to-a-strong-random-secret

# Virtual key for Hyperion agents (created via: see agents/hyperion/scripts/create_hyperion_key.sh)
# Has max_budget=10 USD/day and rpm_limit=60. Store result here after creation.
LITELLM_HYPERION_KEY=sk-hyperion-change-me

# -----------------------------------------------------------------------------
# Shared Postgres (LiteLLM virtual keys + Langfuse)
# -----------------------------------------------------------------------------
# Generate: python3 -c "import secrets; print(secrets.token_hex(16))"
POSTGRES_PASSWORD=change-me-to-a-strong-random-password

# -----------------------------------------------------------------------------
# Open WebUI
# -----------------------------------------------------------------------------
# Session cookie signing key. Generate: openssl rand -hex 32
WEBUI_SECRET_KEY=change-me-to-a-strong-random-secret

# -----------------------------------------------------------------------------
# Langfuse (self-hosted tracing; http://localhost:3001)
# -----------------------------------------------------------------------------
# Generate each with: python3 -c "import secrets; print(secrets.token_hex(32))"
LANGFUSE_NEXTAUTH_SECRET=change-me-langfuse-nextauth-secret
LANGFUSE_SALT=change-me-langfuse-salt
# Required in Langfuse v2.x — 256-bit key for encrypting API keys at rest
# Generate: openssl rand -hex 32
LANGFUSE_ENCRYPTION_KEY=change-me-64-hex-chars

# Auto-created project keys (pre-generate or create via UI after first boot)
# Generate: python3 -c "import secrets; print('pk-lf-' + secrets.token_hex(16))"
LANGFUSE_PUBLIC_KEY=pk-lf-change-me
# Generate: python3 -c "import secrets; print('sk-lf-' + secrets.token_hex(16))"
LANGFUSE_SECRET_KEY=sk-lf-change-me
# Project id for resolvable trace deep-links ({host}/project/{id}/sessions/{task_id}).
# Find it after first boot: curl -u "$PUBLIC_KEY:$SECRET_KEY" http://localhost:3001/api/public/projects
LANGFUSE_PROJECT_ID=

# Admin user credentials for the auto-created account
LANGFUSE_ADMIN_EMAIL=admin@local.dev
LANGFUSE_ADMIN_PASSWORD=change-me-langfuse-admin-password

# -----------------------------------------------------------------------------
# SearXNG (self-hosted search; http://localhost:8888)
# -----------------------------------------------------------------------------
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SEARXNG_SECRET_KEY=change-me-searxng-secret

# -----------------------------------------------------------------------------
# Infinity (reranker; http://localhost:7997)
# -----------------------------------------------------------------------------
# Set to "cuda" if GPU is available (also add Docker deploy.resources block)
INFINITY_DEVICE=cpu

# -----------------------------------------------------------------------------
# Notion (second brain ingestion)
# Used by ~/ai/secondbrain/ingest_notion.py
# -----------------------------------------------------------------------------
# Integration token: https://www.notion.so/my-integrations
NOTION_API_KEY=secret_your_notion_integration_token_here

# Comma-separated Notion database IDs to ingest (get from page URL)
NOTION_DATABASE_IDS=your_database_id_1,your_database_id_2

# Single target database for Hyperion's "save to Notion" follow-up (Phase 9).
# Pick one DB id from above; absent, the follow-up returns a "not configured" error.
NOTION_DATABASE_ID=your_database_id_1

# -----------------------------------------------------------------------------
# Agent workspace (mounted into open-webui container at /workspace)
# -----------------------------------------------------------------------------
AGENT_WORKSPACE_HOST=${HOME}/agent_workspace
GOOGLE_TOKEN_DIR=${HOME}/.config/agent-google

# -----------------------------------------------------------------------------
# fs-mcp (mcpo) — filesystem MCP server exposed to OWUI as an OpenAPI tool server.
# Gives OWUI agents read/write file access to the whole ~/ai workspace.
# Generate: openssl rand -hex 24
# -----------------------------------------------------------------------------
MCPO_API_KEY=change-me-to-a-strong-random-secret
